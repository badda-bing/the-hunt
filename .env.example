# Framework configuration
# -----------------------
# The framework's config loader validates every LLM provider declared in
# app.config.json has its API key present at boot. Copy this to .env.local
# and fill in real values.

# Anthropic API key. Required because app.config.json declares the
# 'default' anthropic provider. Step 1.1 doesn't call the LLM, but the
# boot check still enforces presence. Use a real key for steps 1.2+.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional overrides
# FRAMEWORK_APP_ENV=development
# FRAMEWORK_OBSERVABILITY_LEVEL=info
